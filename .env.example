# Image providers — Clipdrop is preferred when set; otherwise Remove.bg
CLIPDROP_API_KEY=
REMOVE_BG_API_KEY=your_remove_bg_api_key

# Google OAuth + HMAC session cookie
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
AUTH_SECRET=replace_with_a_long_random_secret

# Optional: max claimed remove-bg operations per UTC day (omit or 0 = disabled)
# DAILY_UPSTREAM_LIMIT=2000
# Optional: estimated USD per successful removal for structured logs
# UPSTREAM_COST_USD=0.04

# PayPal (production Functions)
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_SANDBOX=false
# ALLOW_PAYPAL_SANDBOX=
# SITE_URL=https://picturebackgroundremover.xyz

# Admin report
# ADMIN_API_KEY=

# Optional: GA4 measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable analytics.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
